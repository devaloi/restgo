# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=restgo
DB_PASS=restgo
DB_NAME=restgo
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# Server
SERVER_PORT=8080

# CORS
CORS_ORIGINS=*

# Rate Limiting (requests per minute)
RATE_LIMIT=100

# Logging
LOG_LEVEL=info
